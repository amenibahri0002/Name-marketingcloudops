# ============================================
# URL DE L'API BACKEND
# ============================================
# Développement local
REACT_APP_API_URL=http://localhost:5000

# Production (déployé sur Render)
# REACT_APP_API_URL=https://marketingcloudops-backend.onrender.com

# ============================================
# CLÉS PUBLIQUES (non sensibles)
# ============================================
# Firebase Config (public - côté client)
REACT_APP_FIREBASE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REACT_APP_FIREBASE_AUTH_DOMAIN=digilab-ops.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=digilab-ops
REACT_APP_FIREBASE_STORAGE_BUCKET=digilab-ops.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789012
REACT_APP_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Google Analytics (public)
REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX

# ============================================
# FEATURE FLAGS
# ============================================
REACT_APP_ENABLE_CHAT=true
REACT_APP_ENABLE_NOTIFICATIONS=true